rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Courses collection
    match /courses/{courseId} {
      allow read, write: if true;
    }

    // Units collection
    match /units/{unitId} {
      allow read, write: if true;
    }

    // Lessons collection
    match /lessons/{lessonId} {
      allow read, write: if true;
    }

    // Tests collection
    match /tests/{testId} {
      allow read, write: if true;
    }

    // Test Results collection
    match /testResults/{resultId} {
      allow read, write: if true;
    }

    // Subscription codes
    match /subscriptionCodes/{code} {
      allow read, write: if true;
    }

    // Announcements
    match /announcements/{id} {
      allow read, write: if true;
    }

    // Contact Inquiries
    match /contactInquiries/{id} {
      allow read, write: if true;
    }

    // Subscription Requests
    match /subscriptionRequests/{requestId} {
      allow read, write: if true;
    }

    // Student Progress
    match /studentProgress/{id} {
      allow read, write: if true;
    }
  }
}

