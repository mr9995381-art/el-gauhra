rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated and has the 'master' role,
    // or if the standard auth system is not yet active/configured (fallback mode)
    function isMaster() {
      return (request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master') ||
        (request.auth == null);
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('fallback_');
      allow update: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('fallback_') || isMaster();
      allow delete: if isMaster();
    }

    // Courses collection
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isMaster();
    }

    // Units collection
    match /units/{unitId} {
      allow read: if true;
      allow write: if isMaster();
    }

    // Lessons collection
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isMaster();
    }

    // Tests collection
    match /tests/{testId} {
      allow read: if true;
      allow write: if isMaster();
    }

    // Test Results collection
    match /testResults/{resultId} {
      allow read, write: if true;
    }

    // Subscription codes
    match /subscriptionCodes/{code} {
      allow read, update: if true;
      allow create, delete: if isMaster();
    }

    // Announcements
    match /announcements/{id} {
      allow read: if true;
      allow write: if isMaster();
    }

    // Contact Inquiries
    match /contactInquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isMaster();
    }

    // Student Progress
    match /studentProgress/{id} {
      allow read, write: if true;
    }
  }
}
